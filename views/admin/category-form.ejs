<%- include('_header') %>

<div class="panel">
  <div class="panel-header">
    <h3><i class="fas fa-<%= cat ? 'edit' : 'plus' %>"></i> <%= cat ? 'Edit Category' : 'New Category' %></h3>
    <a href="/admin/categories" class="btn btn-outline btn-sm"><i class="fas fa-arrow-left"></i> Back</a>
  </div>
  <div class="panel-body">
    <form action="<%= cat ? '/admin/categories/' + cat.id + '/edit' : '/admin/categories/new' %>" method="POST" enctype="multipart/form-data">
      <div class="form-group"><label>Name *</label><input type="text" name="name" class="form-control" value="<%= cat ? cat.name : '' %>" required></div>
      <div class="form-group"><label>Description</label><textarea name="description" class="form-control" rows="3"><%= cat ? cat.description : '' %></textarea></div>
      <div class="form-row">
        <div class="form-group"><label>Sort Order</label><input type="number" name="sort_order" class="form-control" value="<%= cat ? cat.sort_order : 0 %>"></div>
        <div class="form-group">
          <label>Image</label>
          <input type="file" name="image" class="form-control" accept="image/*">
          <% if (cat && cat.image) { %><div class="form-help"><img src="<%= cat.image %>" style="max-width:120px;border-radius:5px;margin-top:6px"></div><% } %>
        </div>
      </div>
      <button class="btn btn-primary"><i class="fas fa-save"></i> Save</button>
      <a href="/admin/categories" class="btn btn-outline">Cancel</a>
    </form>
  </div>
</div>

<%- include('_footer') %>
