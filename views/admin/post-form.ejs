<%- include('_header') %>

<div class="panel">
  <div class="panel-header">
    <h3><i class="fas fa-<%= post ? 'edit' : 'plus' %>"></i> <%= post ? 'Edit Post' : 'New Post' %></h3>
    <a href="/admin/posts" class="btn btn-outline btn-sm"><i class="fas fa-arrow-left"></i> Back</a>
  </div>
  <div class="panel-body">
    <form action="<%= post ? '/admin/posts/' + post.id + '/edit' : '/admin/posts/new' %>" method="POST" enctype="multipart/form-data">
      <div class="form-group"><label>Title *</label><input type="text" name="title" class="form-control" value="<%= post ? post.title : '' %>" required></div>
      <div class="form-row">
        <div class="form-group"><label>Author</label><input type="text" name="author" class="form-control" value="<%= post ? post.author : 'Bali Adventure Team' %>"></div>
        <div class="form-group"><label>Tags (comma separated)</label><input type="text" name="tags" class="form-control" value="<%= post ? post.tags : '' %>" placeholder="bali, motorbike, tips"></div>
      </div>
      <div class="form-group"><label>Excerpt</label><textarea name="excerpt" class="form-control" rows="2"><%= post ? post.excerpt : '' %></textarea></div>
      <div class="form-group"><label>Content</label><textarea name="content" class="form-control" rows="14"><%= post ? post.content : '' %></textarea></div>
      <div class="form-group">
        <label>Cover Image</label>
        <input type="file" name="image" class="form-control" accept="image/*">
        <% if (post && post.image) { %><div class="form-help"><img src="<%= post.image %>" style="max-width:160px;border-radius:5px;margin-top:6px"></div><% } %>
      </div>
      <div class="form-group checkbox-row">
        <input type="checkbox" id="status" name="status" value="1" <%= !post || post.status ? 'checked' : '' %>>
        <label for="status" style="margin-bottom:0">Published</label>
      </div>
      <button class="btn btn-primary"><i class="fas fa-save"></i> Save</button>
      <a href="/admin/posts" class="btn btn-outline">Cancel</a>
    </form>
  </div>
</div>

<%- include('_footer') %>
