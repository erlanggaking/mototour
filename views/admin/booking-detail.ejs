<%- include('_header') %>

<div style="display:grid;grid-template-columns:2fr 1fr;gap:24px">
  <div class="panel">
    <div class="panel-header">
      <h3><i class="fas fa-calendar-check"></i> Booking #<%= booking.id %></h3>
      <a href="/admin/bookings" class="btn btn-outline btn-sm"><i class="fas fa-arrow-left"></i> Back</a>
    </div>
    <div class="panel-body">
      <table style="width:100%">
        <tr><td style="padding:10px 0;width:200px;color:var(--muted);font-weight:600">Customer Name</td><td><strong><%= booking.full_name %></strong></td></tr>
        <tr><td style="padding:10px 0;color:var(--muted);font-weight:600">Email</td><td><a href="mailto:<%= booking.email %>"><%= booking.email %></a></td></tr>
        <tr><td style="padding:10px 0;color:var(--muted);font-weight:600">Phone</td><td><%= booking.phone || '—' %></td></tr>
        <tr><td style="padding:10px 0;color:var(--muted);font-weight:600">Country</td><td><%= booking.country || '—' %></td></tr>
        <tr><td style="padding:10px 0;color:var(--muted);font-weight:600">Tour</td><td><%= booking.tour_title || '— (custom request)' %></td></tr>
        <tr><td style="padding:10px 0;color:var(--muted);font-weight:600">Travel Date</td><td><%= booking.travel_date || '—' %></td></tr>
        <tr><td style="padding:10px 0;color:var(--muted);font-weight:600">People</td><td><%= booking.num_people %></td></tr>
        <tr><td style="padding:10px 0;color:var(--muted);font-weight:600">Received</td><td><%= new Date(booking.created_at).toLocaleString() %></td></tr>
        <tr><td style="padding:10px 0;color:var(--muted);font-weight:600;vertical-align:top">Message</td><td style="white-space:pre-wrap"><%= booking.message || '—' %></td></tr>
      </table>
    </div>
  </div>

  <div>
    <div class="panel">
      <div class="panel-header"><h3><i class="fas fa-tag"></i> Status</h3></div>
      <div class="panel-body">
        <div style="margin-bottom:12px">Current: <span class="status status-<%= booking.status %>"><%= booking.status %></span></div>
        <form action="/admin/bookings/<%= booking.id %>/status" method="POST">
          <div class="form-group">
            <label>Update Status</label>
            <select name="status" class="form-control">
              <% ['new','pending','confirmed','cancelled'].forEach(s => { %>
                <option value="<%= s %>" <%= booking.status === s ? 'selected' : '' %>><%= s %></option>
              <% }) %>
            </select>
          </div>
          <button class="btn btn-primary btn-block">Update</button>
        </form>
      </div>
    </div>
    <div class="panel">
      <div class="panel-header"><h3><i class="fas fa-bolt"></i> Quick Actions</h3></div>
      <div class="panel-body">
        <a href="mailto:<%= booking.email %>?subject=Your Bali Adventure Booking #<%= booking.id %>" class="btn btn-secondary btn-block" style="margin-bottom:8px"><i class="fas fa-envelope"></i> Reply by Email</a>
        <% if (booking.phone) { %>
          <a href="https://wa.me/<%= booking.phone.replace(/\D/g,'') %>" target="_blank" class="btn btn-success btn-block" style="margin-bottom:8px"><i class="fab fa-whatsapp"></i> WhatsApp</a>
        <% } %>
        <form action="/admin/bookings/<%= booking.id %>/delete" method="POST" onsubmit="return confirm('Delete this booking?')">
          <button class="btn btn-danger btn-block"><i class="fas fa-trash"></i> Delete Booking</button>
        </form>
      </div>
    </div>
  </div>
</div>

<%- include('_footer') %>
