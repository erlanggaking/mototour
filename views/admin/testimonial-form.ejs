<%- include('_header') %>

<div class="panel">
  <div class="panel-header">
    <h3><i class="fas fa-<%= item ? 'edit' : 'plus' %>"></i> <%= item ? 'Edit Testimonial' : 'New Testimonial' %></h3>
    <a href="/admin/testimonials" class="btn btn-outline btn-sm"><i class="fas fa-arrow-left"></i> Back</a>
  </div>
  <div class="panel-body">
    <form action="<%= item ? '/admin/testimonials/' + item.id + '/edit' : '/admin/testimonials/new' %>" method="POST" enctype="multipart/form-data">
      <div class="form-row">
        <div class="form-group"><label>Name *</label><input type="text" name="name" class="form-control" value="<%= item ? item.name : '' %>" required></div>
        <div class="form-group"><label>Country</label><input type="text" name="country" class="form-control" value="<%= item ? item.country : '' %>"></div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>Rating</label>
          <select name="rating" class="form-control">
            <% [5,4,3,2,1].forEach(r => { %>
              <option value="<%= r %>" <%= item && item.rating === r ? 'selected' : '' %>><%= '★'.repeat(r) %> (<%= r %>)</option>
            <% }) %>
          </select>
        </div>
        <div class="form-group checkbox-row">
          <input type="checkbox" id="status" name="status" value="1" <%= !item || item.status ? 'checked' : '' %>>
          <label for="status" style="margin-bottom:0">Visible on website</label>
        </div>
      </div>
      <div class="form-group"><label>Content *</label><textarea name="content" class="form-control" rows="5" required><%= item ? item.content : '' %></textarea></div>
      <button class="btn btn-primary"><i class="fas fa-save"></i> Save</button>
      <a href="/admin/testimonials" class="btn btn-outline">Cancel</a>
    </form>
  </div>
</div>

<%- include('_footer') %>
