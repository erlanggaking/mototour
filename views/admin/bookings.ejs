<%- include('_header') %>

<div class="panel">
  <div class="panel-header">
    <h3><i class="fas fa-calendar-check"></i> All Bookings (<%= bookings.length %>)</h3>
  </div>
  <% if (bookings.length === 0) { %>
    <div class="panel-body" style="text-align:center;color:var(--muted);padding:40px">No bookings yet.</div>
  <% } else { %>
    <table>
      <thead><tr><th>#</th><th>Customer</th><th>Tour</th><th>Travel Date</th><th>People</th><th>Received</th><th>Status</th><th>Actions</th></tr></thead>
      <tbody>
        <% bookings.forEach(b => { %>
          <tr>
            <td>#<%= b.id %></td>
            <td>
              <strong><%= b.full_name %></strong><br>
              <small style="color:var(--muted)"><%= b.email %><% if (b.phone) { %> · <%= b.phone %><% } %></small>
            </td>
            <td><%= b.tour_title || '—' %></td>
            <td><%= b.travel_date || '—' %></td>
            <td><%= b.num_people %></td>
            <td><%= new Date(b.created_at).toLocaleDateString() %></td>
            <td><span class="status status-<%= b.status %>"><%= b.status %></span></td>
            <td>
              <div class="actions">
                <a href="/admin/bookings/<%= b.id %>" class="btn btn-outline btn-sm"><i class="fas fa-eye"></i> View</a>
                <form action="/admin/bookings/<%= b.id %>/delete" method="POST" style="display:inline" onsubmit="return confirm('Delete this booking?')">
                  <button class="btn btn-danger btn-sm"><i class="fas fa-trash"></i></button>
                </form>
              </div>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
</div>

<%- include('_footer') %>
