<%- include('_header') %>

<div class="stat-grid">
  <div class="stat-card">
    <div class="icon"><i class="fas fa-route"></i></div>
    <div>
      <div class="value"><%= stats.tours %></div>
      <div class="label">Total Tours</div>
    </div>
  </div>
  <div class="stat-card">
    <div class="icon"><i class="fas fa-motorcycle"></i></div>
    <div>
      <div class="value"><%= stats.bikes %></div>
      <div class="label">Bikes</div>
    </div>
  </div>
  <div class="stat-card">
    <div class="icon"><i class="fas fa-newspaper"></i></div>
    <div>
      <div class="value"><%= stats.posts %></div>
      <div class="label">Travel Guides</div>
    </div>
  </div>
  <div class="stat-card">
    <div class="icon"><i class="fas fa-folder"></i></div>
    <div>
      <div class="value"><%= stats.categories %></div>
      <div class="label">Categories</div>
    </div>
  </div>
  <div class="stat-card" style="border-left-color: var(--success)">
    <div class="icon" style="background: linear-gradient(135deg, var(--success), #4ade80)"><i class="fas fa-calendar-check"></i></div>
    <div>
      <div class="value"><%= stats.bookings %></div>
      <div class="label">Total Bookings <% if (stats.new_bookings) { %><span class="status status-new"><%= stats.new_bookings %> new</span><% } %></div>
    </div>
  </div>
  <div class="stat-card" style="border-left-color: var(--primary)">
    <div class="icon" style="background: linear-gradient(135deg, var(--primary), #3b82f6)"><i class="fas fa-envelope"></i></div>
    <div>
      <div class="value"><%= stats.contacts %></div>
      <div class="label">Messages <% if (stats.new_contacts) { %><span class="status status-new"><%= stats.new_contacts %> new</span><% } %></div>
    </div>
  </div>
</div>

<div style="display:grid;grid-template-columns:1fr 1fr;gap:24px">
  <div class="panel">
    <div class="panel-header">
      <h3><i class="fas fa-calendar-check"></i> Recent Bookings</h3>
      <a href="/admin/bookings" class="btn btn-outline btn-sm">View All</a>
    </div>
    <% if (recentBookings.length === 0) { %>
      <div class="panel-body" style="text-align:center;color:var(--muted)">No bookings yet</div>
    <% } else { %>
      <table>
        <thead><tr><th>Customer</th><th>Tour</th><th>Date</th><th>Status</th></tr></thead>
        <tbody>
          <% recentBookings.forEach(b => { %>
            <tr>
              <td><a href="/admin/bookings/<%= b.id %>"><%= b.full_name %></a><br><small style="color:var(--muted)"><%= b.email %></small></td>
              <td><%= b.tour_title || '—' %></td>
              <td><%= new Date(b.created_at).toLocaleDateString() %></td>
              <td><span class="status status-<%= b.status %>"><%= b.status %></span></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>
  </div>

  <div class="panel">
    <div class="panel-header">
      <h3><i class="fas fa-envelope"></i> Recent Messages</h3>
      <a href="/admin/contacts" class="btn btn-outline btn-sm">View All</a>
    </div>
    <% if (recentContacts.length === 0) { %>
      <div class="panel-body" style="text-align:center;color:var(--muted)">No messages yet</div>
    <% } else { %>
      <table>
        <thead><tr><th>From</th><th>Subject</th><th>Date</th><th>Status</th></tr></thead>
        <tbody>
          <% recentContacts.forEach(c => { %>
            <tr>
              <td><a href="/admin/contacts/<%= c.id %>"><%= c.full_name %></a></td>
              <td><%= c.subject || '(no subject)' %></td>
              <td><%= new Date(c.created_at).toLocaleDateString() %></td>
              <td><span class="status status-<%= c.status %>"><%= c.status %></span></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>
  </div>
</div>

<%- include('_footer') %>
