<%- include('_header') %>

<div style="display:grid;grid-template-columns:2fr 1fr;gap:24px">
  <div class="panel">
    <div class="panel-header">
      <h3><i class="fas fa-envelope"></i> Message #<%= contact.id %></h3>
      <a href="/admin/contacts" class="btn btn-outline btn-sm"><i class="fas fa-arrow-left"></i> Back</a>
    </div>
    <div class="panel-body">
      <table style="width:100%">
        <tr><td style="padding:10px 0;width:160px;color:var(--muted);font-weight:600">From</td><td><strong><%= contact.full_name %></strong></td></tr>
        <tr><td style="padding:10px 0;color:var(--muted);font-weight:600">Email</td><td><a href="mailto:<%= contact.email %>"><%= contact.email %></a></td></tr>
        <tr><td style="padding:10px 0;color:var(--muted);font-weight:600">Phone</td><td><%= contact.phone || '—' %></td></tr>
        <tr><td style="padding:10px 0;color:var(--muted);font-weight:600">Subject</td><td><%= contact.subject || '(no subject)' %></td></tr>
        <tr><td style="padding:10px 0;color:var(--muted);font-weight:600">Received</td><td><%= new Date(contact.created_at).toLocaleString() %></td></tr>
      </table>
      <hr>
      <h4>Message</h4>
      <div style="background:var(--bg);padding:16px;border-radius:7px;white-space:pre-wrap;line-height:1.7"><%= contact.message %></div>
    </div>
  </div>

  <div class="panel">
    <div class="panel-header"><h3><i class="fas fa-bolt"></i> Actions</h3></div>
    <div class="panel-body">
      <a href="mailto:<%= contact.email %>?subject=Re: <%= contact.subject || 'Your message' %>" class="btn btn-primary btn-block" style="margin-bottom:8px"><i class="fas fa-reply"></i> Reply by Email</a>
      <% if (contact.phone) { %>
        <a href="https://wa.me/<%= contact.phone.replace(/\D/g,'') %>" target="_blank" class="btn btn-success btn-block" style="margin-bottom:8px"><i class="fab fa-whatsapp"></i> WhatsApp</a>
      <% } %>
      <form action="/admin/contacts/<%= contact.id %>/delete" method="POST" onsubmit="return confirm('Delete this message?')">
        <button class="btn btn-danger btn-block"><i class="fas fa-trash"></i> Delete</button>
      </form>
    </div>
  </div>
</div>

<%- include('_footer') %>
