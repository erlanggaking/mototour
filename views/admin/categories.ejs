<%- include('_header') %>

<div class="panel">
  <div class="panel-header">
    <h3><i class="fas fa-folder"></i> Tour Categories (<%= cats.length %>)</h3>
    <a href="/admin/categories/new" class="btn btn-primary"><i class="fas fa-plus"></i> Add Category</a>
  </div>
  <% if (cats.length === 0) { %>
    <div class="panel-body" style="text-align:center;color:var(--muted);padding:40px">No categories yet.</div>
  <% } else { %>
    <table>
      <thead><tr><th>Image</th><th>Name</th><th>Slug</th><th>Description</th><th>Order</th><th>Actions</th></tr></thead>
      <tbody>
        <% cats.forEach(c => { %>
          <tr>
            <td><% if (c.image) { %><img src="<%= c.image %>" class="thumb" onerror="this.style.display='none'"><% } else { %>—<% } %></td>
            <td><strong><%= c.name %></strong></td>
            <td><code style="font-size:12px;color:var(--muted)"><%= c.slug %></code></td>
            <td style="font-size:13px"><%= (c.description || '').slice(0, 80) %></td>
            <td><%= c.sort_order %></td>
            <td>
              <div class="actions">
                <a href="/admin/categories/<%= c.id %>/edit" class="btn btn-secondary btn-sm"><i class="fas fa-edit"></i></a>
                <form action="/admin/categories/<%= c.id %>/delete" method="POST" style="display:inline" onsubmit="return confirm('Delete this category?')">
                  <button class="btn btn-danger btn-sm"><i class="fas fa-trash"></i></button>
                </form>
              </div>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
</div>

<%- include('_footer') %>
