<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= title %> | Admin · <%= site.site_name %></title>
<link rel="stylesheet" href="/css/admin.css">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
<div class="admin-layout">
  <aside class="sidebar">
    <div class="sidebar-header">
      <div class="badge">B</div>
      <div>
        <strong><%= site.site_name %></strong>
        <span>Admin Panel</span>
      </div>
    </div>
    <ul class="sidebar-menu">
      <li><a href="/admin" class="<%= currentPath === '/admin' ? 'active' : '' %>"><i class="fas fa-tachometer-alt"></i> Dashboard</a></li>
      <li class="group-title">Content</li>
      <li><a href="/admin/tours" class="<%= currentPath.startsWith('/admin/tours') ? 'active' : '' %>"><i class="fas fa-route"></i> Tours</a></li>
      <li><a href="/admin/categories" class="<%= currentPath.startsWith('/admin/categories') ? 'active' : '' %>"><i class="fas fa-folder"></i> Tour Categories</a></li>
      <li><a href="/admin/bikes" class="<%= currentPath.startsWith('/admin/bikes') ? 'active' : '' %>"><i class="fas fa-motorcycle"></i> Bikes</a></li>
      <li><a href="/admin/posts" class="<%= currentPath.startsWith('/admin/posts') ? 'active' : '' %>"><i class="fas fa-newspaper"></i> Travel Guides</a></li>
      <li><a href="/admin/team" class="<%= currentPath.startsWith('/admin/team') ? 'active' : '' %>"><i class="fas fa-users"></i> Team</a></li>
      <li><a href="/admin/testimonials" class="<%= currentPath.startsWith('/admin/testimonials') ? 'active' : '' %>"><i class="fas fa-quote-left"></i> Testimonials</a></li>
      <li class="group-title">Customer</li>
      <li><a href="/admin/bookings" class="<%= currentPath.startsWith('/admin/bookings') ? 'active' : '' %>"><i class="fas fa-calendar-check"></i> Bookings</a></li>
      <li><a href="/admin/contacts" class="<%= currentPath.startsWith('/admin/contacts') ? 'active' : '' %>"><i class="fas fa-envelope"></i> Messages</a></li>
      <li class="group-title">System</li>
      <li><a href="/admin/settings" class="<%= currentPath.startsWith('/admin/settings') ? 'active' : '' %>"><i class="fas fa-cog"></i> Site Settings</a></li>
      <li><a href="/admin/users" class="<%= currentPath.startsWith('/admin/users') ? 'active' : '' %>"><i class="fas fa-user-shield"></i> Admin Users</a></li>
      <li><a href="/" target="_blank"><i class="fas fa-external-link-alt"></i> View Website</a></li>
      <li><a href="/admin/logout" style="color:#fda4af"><i class="fas fa-sign-out-alt"></i> Logout</a></li>
    </ul>
  </aside>
  <main class="admin-main">
    <div class="admin-topbar">
      <h2><%= title %></h2>
      <div class="user-info">
        <i class="fas fa-user-circle" style="font-size:22px;color:var(--primary)"></i>
        <span><strong><%= user.full_name || user.username %></strong></span>
        <a href="/admin/logout"><i class="fas fa-sign-out-alt"></i> Logout</a>
      </div>
    </div>
    <div class="admin-content">
