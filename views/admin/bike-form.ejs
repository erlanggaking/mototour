<%- include('_header') %>

<div class="panel">
  <div class="panel-header">
    <h3><i class="fas fa-<%= bike ? 'edit' : 'plus' %>"></i> <%= bike ? 'Edit Bike' : 'New Bike' %></h3>
    <a href="/admin/bikes" class="btn btn-outline btn-sm"><i class="fas fa-arrow-left"></i> Back</a>
  </div>
  <div class="panel-body">
    <form action="<%= bike ? '/admin/bikes/' + bike.id + '/edit' : '/admin/bikes/new' %>" method="POST" enctype="multipart/form-data">
      <div class="form-row">
        <div class="form-group"><label>Name *</label><input type="text" name="name" class="form-control" value="<%= bike ? bike.name : '' %>" required></div>
        <div class="form-group"><label>Brand</label><input type="text" name="brand" class="form-control" value="<%= bike ? bike.brand : '' %>"></div>
      </div>
      <div class="form-row-3">
        <div class="form-group"><label>CC</label><input type="text" name="cc" class="form-control" value="<%= bike ? bike.cc : '' %>" placeholder="e.g. 250cc"></div>
        <div class="form-group"><label>Type</label><input type="text" name="type" class="form-control" value="<%= bike ? bike.type : '' %>" placeholder="e.g. Adventure, Trail"></div>
        <div class="form-group"><label>Daily Rate (USD)</label><input type="number" step="0.01" name="daily_rate" class="form-control" value="<%= bike ? bike.daily_rate : 0 %>"></div>
      </div>
      <div class="form-group"><label>Description</label><textarea name="description" class="form-control" rows="4"><%= bike ? bike.description : '' %></textarea></div>
      <div class="form-group">
        <label>Image</label>
        <input type="file" name="image" class="form-control" accept="image/*">
        <% if (bike && bike.image) { %><div class="form-help"><img src="<%= bike.image %>" style="max-width:160px;border-radius:5px;margin-top:6px"></div><% } %>
      </div>
      <div class="form-group checkbox-row">
        <input type="checkbox" id="status" name="status" value="1" <%= !bike || bike.status ? 'checked' : '' %>>
        <label for="status" style="margin-bottom:0">Active (visible on website)</label>
      </div>
      <button class="btn btn-primary"><i class="fas fa-save"></i> Save</button>
      <a href="/admin/bikes" class="btn btn-outline">Cancel</a>
    </form>
  </div>
</div>

<%- include('_footer') %>
