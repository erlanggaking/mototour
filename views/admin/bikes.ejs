<%- include('_header') %>

<div class="panel">
  <div class="panel-header">
    <h3><i class="fas fa-motorcycle"></i> Bikes (<%= bikes.length %>)</h3>
    <a href="/admin/bikes/new" class="btn btn-primary"><i class="fas fa-plus"></i> Add Bike</a>
  </div>
  <% if (bikes.length === 0) { %>
    <div class="panel-body" style="text-align:center;color:var(--muted);padding:40px">No bikes yet.</div>
  <% } else { %>
    <table>
      <thead><tr><th>Image</th><th>Name</th><th>Brand</th><th>CC</th><th>Type</th><th>Rate</th><th>Status</th><th>Actions</th></tr></thead>
      <tbody>
        <% bikes.forEach(b => { %>
          <tr>
            <td><% if (b.image) { %><img src="<%= b.image %>" class="thumb" onerror="this.style.display='none'"><% } else { %>—<% } %></td>
            <td><strong><%= b.name %></strong></td>
            <td><%= b.brand %></td>
            <td><%= b.cc %></td>
            <td><%= b.type %></td>
            <td>$<%= Math.round(b.daily_rate) %>/day</td>
            <td><span class="status status-<%= b.status ? 'active' : 'inactive' %>"><%= b.status ? 'Active' : 'Hidden' %></span></td>
            <td>
              <div class="actions">
                <a href="/bike/<%= b.slug %>" target="_blank" class="btn btn-outline btn-sm"><i class="fas fa-eye"></i></a>
                <a href="/admin/bikes/<%= b.id %>/edit" class="btn btn-secondary btn-sm"><i class="fas fa-edit"></i></a>
                <form action="/admin/bikes/<%= b.id %>/delete" method="POST" style="display:inline" onsubmit="return confirm('Delete this bike?')">
                  <button class="btn btn-danger btn-sm"><i class="fas fa-trash"></i></button>
                </form>
              </div>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
</div>

<%- include('_footer') %>
