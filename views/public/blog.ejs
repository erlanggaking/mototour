<%- include('../partials/header') %>

<section class="page-banner">
  <div class="container">
    <h1>Travel Guides</h1>
    <div class="breadcrumb"><a href="/">Home</a> / Travel Guides</div>
  </div>
</section>

<section>
  <div class="container">
    <% if (posts.length === 0) { %>
      <div class="empty-state"><i class="far fa-newspaper"></i><h3>No articles yet</h3></div>
    <% } else { %>
      <div class="cards-grid">
        <% posts.forEach(p => { %>
          <div class="card">
            <div class="card-img">
              <% if (p.image) { %><img src="<%= p.image %>" alt="<%= p.title %>" onerror="this.style.display='none'"><% } %>
            </div>
            <div class="card-body">
              <div class="card-cat"><i class="far fa-calendar"></i> <%= new Date(p.created_at).toLocaleDateString('en-US', {year:'numeric',month:'short',day:'numeric'}) %></div>
              <h3 class="card-title"><a href="/blog/<%= p.slug %>"><%= p.title %></a></h3>
              <p class="card-desc"><%= p.excerpt %></p>
              <a href="/blog/<%= p.slug %>" class="btn btn-outline btn-sm">Read More</a>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>
</section>

<%- include('../partials/footer') %>
