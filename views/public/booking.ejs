<%- include('../partials/header') %>

<section class="page-banner">
  <div class="container">
    <h1>Book Your Tour</h1>
    <div class="breadcrumb"><a href="/">Home</a> / Booking</div>
  </div>
</section>

<section>
  <div class="container" style="max-width:780px">
    <% if (success) { %>
      <div class="alert alert-success" style="font-size:16px;padding:24px">
        <h3 style="margin:0 0 8px;color:#15803d"><i class="fas fa-check-circle"></i> Booking Received!</h3>
        Thank you for choosing <%= site.site_name %>. We've received your booking request and will contact you within 24 hours to confirm details and arrange payment.
        <div style="margin-top:18px"><a href="/" class="btn btn-secondary">Back to Home</a></div>
      </div>
    <% } else { %>
      <div class="booking-card" style="position:static;max-width:none">
        <h2 style="margin-top:0;text-align:center">Send a Booking Request</h2>
        <p style="text-align:center;color:var(--text-muted);margin-bottom:24px">Fill out the form and our team will be in touch within 24 hours.</p>
        <% if (typeof error !== 'undefined' && error) { %>
          <div class="alert alert-error"><%= error %></div>
        <% } %>
        <form action="/booking" method="POST">
          <div class="form-group">
            <label>Tour</label>
            <select name="tour_id" class="form-control">
              <option value="">Select a tour (or leave blank for custom)</option>
              <% tours.forEach(t => { %>
                <option value="<%= t.id %>" <%= tourId == t.id ? 'selected' : '' %>><%= t.title %></option>
              <% }) %>
            </select>
          </div>
          <div class="form-row">
            <div class="form-group"><label>Full Name *</label><input type="text" name="full_name" class="form-control" required></div>
            <div class="form-group"><label>Email *</label><input type="email" name="email" class="form-control" required></div>
          </div>
          <div class="form-row">
            <div class="form-group"><label>Phone / WhatsApp</label><input type="tel" name="phone" class="form-control"></div>
            <div class="form-group"><label>Country</label><input type="text" name="country" class="form-control"></div>
          </div>
          <div class="form-row">
            <div class="form-group"><label>Preferred Travel Date</label><input type="date" name="travel_date" class="form-control"></div>
            <div class="form-group"><label>Number of People</label><input type="number" name="num_people" class="form-control" value="1" min="1"></div>
          </div>
          <div class="form-group">
            <label>Message / Special Requests</label>
            <textarea name="message" class="form-control" rows="5" placeholder="Tell us about your riding experience, preferences, etc."></textarea>
          </div>
          <button class="btn btn-primary btn-block btn-lg">Submit Booking Request</button>
          <p style="text-align:center;margin-top:16px;font-size:13px;color:var(--text-muted)">
            <i class="fas fa-lock"></i> No payment required to enquire. We'll confirm details before any payment.
          </p>
        </form>
      </div>
    <% } %>
  </div>
</section>

<%- include('../partials/footer') %>
