<%- include('../partials/header') %>

<section class="page-banner">
  <div class="container">
    <h1>Contact Us</h1>
    <div class="breadcrumb"><a href="/">Home</a> / Contact</div>
  </div>
</section>

<section>
  <div class="container">
    <div class="tour-detail-grid" style="grid-template-columns:1fr 1fr">
      <div>
        <h2>Get In Touch</h2>
        <p>Have a question about a tour, want to plan a custom route, or ready to book? Drop us a line and one of our team will get back to you within 24 hours.</p>

        <div style="margin-top:30px">
          <div class="contact-line" style="display:flex;gap:14px;margin-bottom:18px;align-items:flex-start">
            <div style="width:46px;height:46px;background:linear-gradient(135deg,var(--primary),var(--accent));color:#fff;border-radius:50%;display:grid;place-items:center;flex-shrink:0"><i class="fas fa-map-marker-alt"></i></div>
            <div>
              <strong style="color:var(--primary-dark)">Address</strong><br>
              <span style="color:var(--text-muted)"><%= site.address %></span>
            </div>
          </div>
          <div class="contact-line" style="display:flex;gap:14px;margin-bottom:18px;align-items:flex-start">
            <div style="width:46px;height:46px;background:linear-gradient(135deg,var(--primary),var(--accent));color:#fff;border-radius:50%;display:grid;place-items:center;flex-shrink:0"><i class="fas fa-phone"></i></div>
            <div>
              <strong style="color:var(--primary-dark)">Phone / WhatsApp</strong><br>
              <a href="tel:<%= site.phone %>"><%= site.phone %></a>
            </div>
          </div>
          <div class="contact-line" style="display:flex;gap:14px;margin-bottom:18px;align-items:flex-start">
            <div style="width:46px;height:46px;background:linear-gradient(135deg,var(--primary),var(--accent));color:#fff;border-radius:50%;display:grid;place-items:center;flex-shrink:0"><i class="fas fa-envelope"></i></div>
            <div>
              <strong style="color:var(--primary-dark)">Email</strong><br>
              <a href="mailto:<%= site.email %>"><%= site.email %></a>
            </div>
          </div>
          <div class="contact-line" style="display:flex;gap:14px;margin-bottom:18px;align-items:flex-start">
            <div style="width:46px;height:46px;background:linear-gradient(135deg,var(--primary),var(--accent));color:#fff;border-radius:50%;display:grid;place-items:center;flex-shrink:0"><i class="far fa-clock"></i></div>
            <div>
              <strong style="color:var(--primary-dark)">Office Hours</strong><br>
              <span style="color:var(--text-muted)">Mon - Sun · 8:00 AM - 8:00 PM (GMT+8)</span>
            </div>
          </div>
        </div>
      </div>

      <div class="booking-card" style="position:static">
        <h3 style="margin-top:0">Send a Message</h3>
        <% if (success) { %>
          <div class="alert alert-success">
            <i class="fas fa-check-circle"></i> Thanks! Your message has been received. We'll get back to you within 24 hours.
          </div>
        <% } %>
        <% if (typeof error !== 'undefined' && error) { %>
          <div class="alert alert-error"><%= error %></div>
        <% } %>
        <form action="/contact-us" method="POST">
          <div class="form-row">
            <div class="form-group">
              <label>Full Name *</label>
              <input type="text" name="full_name" class="form-control" required>
            </div>
            <div class="form-group">
              <label>Email *</label>
              <input type="email" name="email" class="form-control" required>
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label>Phone</label>
              <input type="tel" name="phone" class="form-control">
            </div>
            <div class="form-group">
              <label>Subject</label>
              <input type="text" name="subject" class="form-control" placeholder="Tour enquiry">
            </div>
          </div>
          <div class="form-group">
            <label>Message *</label>
            <textarea name="message" class="form-control" rows="6" required placeholder="Tell us about your trip..."></textarea>
          </div>
          <button class="btn btn-primary btn-block btn-lg">Send Message</button>
        </form>
      </div>
    </div>
  </div>
</section>

<%- include('../partials/footer') %>
